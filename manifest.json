{
  "manifest_version": 3,
  "name": "SmartWatch",
  "description": "Analyze YouTube videos against your goals with Gemini.",
  "version": "1.0.0",
  "icons": {
    "16": "smartwatch_extension.png",
    "32": "smartwatch_extension.png",
    "48": "smartwatch_extension.png",
    "128": "smartwatch_extension.png"
  },
  "permissions": ["activeTab", "storage", "scripting", "sidePanel", "webNavigation"],
  "host_permissions": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open SmartWatch",
    "default_icon": {
      "16": "smartwatch_extension.png",
      "32": "smartwatch_extension.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
